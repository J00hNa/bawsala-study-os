# Exact frontend origins only. Do not use *.
ALLOWED_ORIGINS=http://localhost:8080,https://study.example.com

# Long random value used only by the scheduled purge caller.
ACCOUNT_PURGE_CRON_SECRET=replace-with-at-least-32-random-bytes

# Supabase injects SUPABASE_URL, SUPABASE_ANON_KEY, and SUPABASE_SERVICE_ROLE_KEY.
# Never expose the service-role key or cron secret in frontend files.
