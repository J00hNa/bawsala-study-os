# Bawsala Study OS v16.0.1 production environment sample
NODE_ENV=production
PORT=8080

# Persistent state. SQLite requires one application process and a persistent writable volume.
# Docker default: /var/lib/bawsala
# Render persistent disk recommendation: mount /var/data, then use /var/data/bawsala
BAWSALA_DATA_DIR=/var/data/bawsala
BAWSALA_STORAGE=sqlite
BAWSALA_INSTANCE_COUNT=1

# Canonical HTTPS origin and explicit Host allowlist.
BAWSALA_PUBLIC_BASE_URL=https://your-domain.example
BAWSALA_ALLOWED_HOSTS=your-domain.example

# Fail startup when critical production configuration is missing.
BAWSALA_ENFORCE_PRODUCTION_CONFIG=true

# One-time first-admin bootstrap. Send it only in the X-Bawsala-Setup-Token header.
# Disable the flag and remove the token immediately after the first administrator is created.
BAWSALA_ALLOW_ADMIN_BOOTSTRAP_HEADER=true
BAWSALA_SETUP_ADMIN_TOKEN=replace-with-32-plus-random-characters

# Independent stable secrets. Never reuse or commit real values.
BAWSALA_SECURITY_PEPPER=replace-with-32-plus-random-characters
BAWSALA_PASSWORD_PEPPER=replace-with-a-different-32-plus-random-value
BAWSALA_HEALTH_DETAILS_TOKEN=replace-with-another-32-plus-random-value

# Authentication and account policy.
BAWSALA_MAX_SESSIONS_PER_USER=5
BAWSALA_STRICT_SESSION_BINDING=false
# Admin sessions are always invalidated on fingerprint mismatch regardless of this setting.
BAWSALA_MFA_ENCRYPTION_KEY=replace-with-an-independent-32-plus-random-value
BAWSALA_DISABLE_PUBLIC_SIGNUPS=true
BAWSALA_STRICT_FETCH_METADATA=true

# Reverse proxy. Forwarded headers are accepted only from explicit proxy IP/CIDR values.
TRUST_PROXY=true
BAWSALA_TRUSTED_PROXY_IPS=127.0.0.1,::1
BAWSALA_TRUST_PROXY_HOPS=1

# Optional administrator network restriction.
BAWSALA_ADMIN_IP_ALLOWLIST=

# Mail delivery. Public signup should stay disabled until this is proven in staging.
BAWSALA_MAIL_PROVIDER=webhook
BAWSALA_MAIL_WEBHOOK_URL=https://mail-adapter.example/send
BAWSALA_MAIL_WEBHOOK_TOKEN=replace-with-provider-token
BAWSALA_MAIL_FROM=noreply@your-verified-domain.example
BAWSALA_MAIL_MAX_ATTEMPTS=5
BAWSALA_MAIL_MAX_PENDING=5000
BAWSALA_MAIL_LEASE_MS=300000
BAWSALA_MAIL_SENT_RETENTION_DAYS=30

# Stripe subscriptions.
BAWSALA_PAYMENT_PROVIDER=stripe
BAWSALA_STRIPE_SECRET_KEY=sk_live_replace
BAWSALA_STRIPE_WEBHOOK_SECRET=whsec_replace
BAWSALA_STRIPE_PRICE_PLUS_MONTHLY=price_replace_monthly
BAWSALA_STRIPE_PRICE_PLUS_YEARLY=price_replace_yearly
BAWSALA_STRIPE_WEBHOOK_TOLERANCE_SECONDS=300

# Legal identity is mandatory before billing can be enabled.
BAWSALA_LEGAL_ENTITY_NAME=
BAWSALA_LEGAL_ENTITY_ADDRESS=
BAWSALA_LEGAL_JURISDICTION=
# Use the registered tax identifier, or an explicit legally accurate value such as not-applicable.
BAWSALA_LEGAL_TAX_ID=
BAWSALA_LEGAL_CONTACT_EMAIL=
BAWSALA_REFUND_POLICY_VERSION=
# Explicitly configure 0 when no voluntary refund window is offered, subject to mandatory law.
BAWSALA_REFUND_WINDOW_DAYS=

# Generic provider alternative. These are trusted server-to-server JSON APIs; never browser URLs with PII in query strings.
BAWSALA_PAYMENT_CHECKOUT_API_URL=
BAWSALA_PAYMENT_PORTAL_API_URL=
BAWSALA_PAYMENT_WEBHOOK_SECRET=

# Google OAuth and optional Calendar synchronization.
BAWSALA_GOOGLE_CLIENT_ID=
BAWSALA_GOOGLE_CLIENT_SECRET=
BAWSALA_GOOGLE_REDIRECT_URI=https://your-domain.example/api/auth/google/callback
BAWSALA_GOOGLE_CALENDAR_ENABLED=false
BAWSALA_OAUTH_ENCRYPTION_KEY=replace-with-a-separate-32-plus-random-value
BAWSALA_GOOGLE_CALENDAR_ID=primary
BAWSALA_GOOGLE_SYNC_PAST_DAYS=30
BAWSALA_GOOGLE_SYNC_FUTURE_DAYS=365

# Backups and security logs. The encryption key is mandatory in production even when off-site upload is disabled.
BAWSALA_BACKUP_SCHEDULE=daily
# Avoid blocking every web-process start; scheduled backups remain enabled below.
BAWSALA_BACKUP_ON_STARTUP=false
BAWSALA_BACKUP_KEEP=20
BAWSALA_BACKUP_MAX_BYTES=16777216
BAWSALA_BACKUP_UPLOAD_URL=https://backup-vault.example/upload
BAWSALA_BACKUP_UPLOAD_TOKEN=replace-with-backup-vault-token
BAWSALA_BACKUP_ENCRYPTION_KEY=replace-with-separate-32-plus-random-value
BAWSALA_REQUIRE_OFFSITE_BACKUPS=true
BAWSALA_BACKUP_UPLOAD_TIMEOUT_MS=15000
BAWSALA_LOG_RETENTION_DAYS=90
BAWSALA_SECURITY_LOG_JSONL=true
BAWSALA_SECURITY_LOG_MAX_BYTES=8388608

# Operational alerts and runtime tuning.
BAWSALA_ALERT_WEBHOOK_URL=https://alerts.example/events
BAWSALA_ALERT_WEBHOOK_TOKEN=replace-with-alert-token
BAWSALA_METRICS_SAMPLES=800
BAWSALA_METRICS_RECENT=100
BAWSALA_SLOW_REQUEST_MS=750
BAWSALA_MAX_ACTIVE_REQUESTS=250

# Development-only escape hatches. Never enable these in production.
BAWSALA_ALLOW_DEV_ADMIN_BOOTSTRAP=false
BAWSALA_ALLOW_DEV_RESET_LINKS=false
BAWSALA_ALLOW_PUBLIC_DEV_BIND=false
BAWSALA_ALLOW_LEGACY_PLAINTEXT_BACKUPS=false
